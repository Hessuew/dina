{
  "name": "christ-dina",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "bun run test && bun run test:integration",
    "typecheck": "tsc --noEmit --noUnusedLocals false --noUnusedParameters false",
    "deploy": "bun run build && wrangler deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:baseline": "bun run scripts/baseline-migrations.ts",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "docs:notion-check": "node scripts/notion-check.mjs",
    "quality:fix": "node scripts/quality-fix.mjs",
    "quality:gate": "node scripts/quality-gate.mjs",
    "check": "prettier --write . && eslint --fix"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/core": "^6.3.1",
