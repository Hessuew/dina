  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.33.1",
    "@electric-sql/pglite": "^0.5.1",
    "@tailwindcss/vite": "^4.2.1",
    "drizzle-kit": "^0.31.9",
    "vite-tsconfig-paths": "^6.1.1",
    "@tanstack/devtools-vite": "^0.3.12",
    "@tanstack/eslint-config": "^0.3.4",
    "@testing-library/dom": "^10.4.1",
