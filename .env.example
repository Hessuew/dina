# Supabase Configuration
# Local development must use the hosted persistent `development` branch, never
# the production branch. See docs/SUPABASE_ENVIRONMENTS.md.
SUPABASE_ENVIRONMENT=development
SUPABASE_PRODUCTION_PROJECT_REF=your-production-project-ref
SUPABASE_URL=https://your-development-branch-ref.supabase.co
SUPABASE_ANON_KEY=your-development-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-development-service-role-key

# Client-side Supabase (exposed to browser)
VITE_SUPABASE_URL=https://your-development-branch-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-development-anon-key

# Application URL
APP_URL=http://localhost:3000

# Resend API Key for sending emails
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM="Disciplers of Nations Academy (DINA) <info@christ-dina.org>"

# Sentry
# SENTRY_AUTH_TOKEN is used by build/source-map upload tooling.
# SENTRY_AXI_AUTH_TOKEN is used by scripts/sentry-axi.mjs for agent triage calls
# (scopes: org:read event:read event:admin). SENTRY_AUTH_TOKEN stays reserved for
# source-map uploads. DINA defaults for axi / fix-sentry skill:
VITE_SENTRY_DSN=your-public-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-build-upload-token
SENTRY_AXI_AUTH_TOKEN=your-sentry-agent-triage-token
SENTRY_ORG=cherubim-it
SENTRY_PROJECT=dina

# WhatsApp Cloud API (Meta) — template messaging from the academy's official number
# Get these from Meta Business Suite > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=your-system-user-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v21.0

# Database URL for Drizzle ORM
# Use Supabase's connection pooler (port 6543) for better performance
# Get this from Supabase Dashboard > Project Settings > Database > Connection String > Connection Pooler
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Note: We use app-level authorization with Supabase instead of RLS policies
DATABASE_URL=postgresql://postgres.your-development-branch-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# Synthetic account created only in the hosted development branch by
# `bun run db:seed:development`. Use an SMTP-approved test address.
DEVELOPMENT_SEED_EMAIL=your-approved-test-email@example.com
DEVELOPMENT_SEED_PASSWORD=replace-with-a-secret-password
