# Supabase Configuration
SUPABASE_URL=your-project-url
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Client-side Supabase (exposed to browser)
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Application URL
APP_URL=http://localhost:3000

# Resend API Key for sending emails
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Database URL for Drizzle ORM
# Use Supabase's connection pooler (port 6543) for better performance
# Get this from Supabase Dashboard > Project Settings > Database > Connection String > Connection Pooler
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Note: We use app-level authorization with Clerk instead of RLS policies
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres