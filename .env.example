# Supabase Configuration
SUPABASE_URL=your-project-url
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Client-side Supabase (exposed to browser)
VITE_SUPABASE_URL=your-project-url
VITE_SUPABASE_ANON_KEY=your-anon-key

# Application URL
APP_URL=http://localhost:3000

# Resend API Key for sending emails
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM="Disciplers of Nations Academy (DINA) <info@christ-dina.org>"

# Sentry
# SENTRY_AUTH_TOKEN is used by build/source-map upload tooling.
# SENTRY_AXI_AUTH_TOKEN is used by scripts/sentry-axi.mjs for agent triage calls.
VITE_SENTRY_DSN=your-public-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-build-upload-token
SENTRY_AXI_AUTH_TOKEN=your-sentry-agent-triage-token
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# WhatsApp Cloud API (Meta) — template messaging from the academy's official number
# Get these from Meta Business Suite > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=your-system-user-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_API_VERSION=v21.0

# Database URL for Drizzle ORM
# Use Supabase's connection pooler (port 6543) for better performance
# Get this from Supabase Dashboard > Project Settings > Database > Connection String > Connection Pooler
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# Note: We use app-level authorization with Supabase instead of RLS policies
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
